# Required for live GitHub data collection
# Use the raw token value only (do not include a 'Bearer ' or 'token ' prefix).
# Restart the dev server after changing this value locally.
GITHUB_TOKEN=ghp_your_token_here

# Optional tuning values
GITHUB_ORG=zephyrproject-rtos
SNAPSHOT_TTL_MINUTES=15
SEARCH_PAGE_LIMIT=15
PR_DETAIL_LIMIT=40
